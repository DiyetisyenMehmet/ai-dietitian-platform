# Base URL of the backend REST API (configured per environment).
NEXT_PUBLIC_API_BASE_URL=

# Auth endpoint paths (relative to NEXT_PUBLIC_API_BASE_URL).
# Optional — override only if the backend uses different paths than the
# conventional defaults shown below. The backend REST contract is not yet
# frozen in this repo; these are configurable, not hardcoded assumptions.
# NEXT_PUBLIC_AUTH_LOGIN_PATH=/auth/login
# NEXT_PUBLIC_AUTH_REGISTER_PATH=/auth/register
# NEXT_PUBLIC_AUTH_FORGOT_PASSWORD_PATH=/auth/forgot-password
# NEXT_PUBLIC_AUTH_RESET_PASSWORD_PATH=/auth/reset-password
# NEXT_PUBLIC_AUTH_VERIFY_EMAIL_PATH=/auth/verify-email
