// Prisma schema — AI Dietitian Platform (backend foundation).
//
// This is the initial, default setup only. No business/domain models are
// defined here yet; domain models are introduced in later sprints. Keeping
// this baseline lets us wire up the client, connection and migration flow
// without committing to any schema decisions prematurely.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Infrastructure baseline table (NOT a business/domain model).
///
/// It exists solely so the initial migration and generated client are
/// meaningful, and so the readiness probe can exercise a real table round-trip.
/// Domain models are introduced in later sprints.
model HealthCheck {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  @@map("health_checks")
}

// ---------------------------------------------------------------------------
// Auth domain (Sprint 8)
// ---------------------------------------------------------------------------

/// Application-level roles. Coarse-grained authorization for V1; finer
/// permissions can be layered later without breaking this contract.
enum UserRole {
  USER
  ADMIN
}

/// A registered account. Only authentication-relevant fields live here; the
/// richer nutrition profile (onboarding: age, height, allergies, etc.) is a
/// separate domain model introduced in a later sprint. `onboardingCompleted`
/// is kept here so the mandatory-onboarding gate can be enforced cheaply on
/// every authenticated request without a join.
model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  /// bcrypt hash — the plaintext password is never stored.
  passwordHash        String
  fullName            String?
  role                UserRole         @default(USER)
  isActive            Boolean          @default(true)
  emailVerifiedAt     DateTime?
  onboardingCompleted Boolean          @default(false)
  /// Subscription tier driving AI usage quotas (Sprint 14, C5). Defaults to
  /// FREE; the payments sprint (Sprint 15) owns transitions between tiers. Kept
  /// here so quota checks resolve the tier cheaply without a join.
  subscriptionTier    SubscriptionTier @default(FREE)
  lastLoginAt         DateTime?
  /// Set when the user requests account deletion. The account enters a grace
  /// period during which the request can be canceled; after it elapses the
  /// account is eligible for permanent deletion. `null` means no pending request.
  deletionRequestedAt DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  refreshTokens     RefreshToken[]
  profile           UserProfile?
  accountTokens     AccountToken[]
  bloodTestUploads  BloodTestUpload[]
  bloodTestAnalyses BloodTestAnalysis[]
  nutritionPlans    NutritionPlan[]
  chatConversations ChatConversation[]
  aiUsageEvents     AiUsageEvent[]
  subscriptions     Subscription[]
  payments          Payment[]
  consents          ConsentRecord[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// Onboarding / nutrition profile domain (Sprint 9)
// ---------------------------------------------------------------------------

/// Biological sex / gender used for calorie & macro baselines. `PREFER_NOT_TO_SAY`
/// is offered for user comfort; downstream calculations fall back to a neutral
/// baseline when it is selected.
enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

/// Physical activity level — maps to a standard activity multiplier used later
/// when estimating energy expenditure.
enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

/// High-level dietary pattern guiding meal/plan generation in later sprints.
enum DietaryPreference {
  OMNIVORE
  VEGETARIAN
  VEGAN
  PESCATARIAN
  KETO
  PALEO
  MEDITERRANEAN
  GLUTEN_FREE
  OTHER
}

/// The mandatory onboarding profile captured on first login/registration.
///
/// One-to-one with `User`. Age is intentionally NOT stored — it is derived from
/// `dateOfBirth` on read so it never drifts. `healthConditions` and `allergies`
/// are free-form string lists (presets + custom entries) kept simple for V1.
model UserProfile {
  id                String            @id @default(uuid())
  userId            String            @unique
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth       DateTime          @db.Date
  gender            Gender
  heightCm          Float
  currentWeightKg   Float
  targetWeightKg    Float
  activityLevel     ActivityLevel
  healthConditions  String[]
  allergies         String[]
  dietaryPreference DietaryPreference
  dailyWaterGoalMl  Int
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@map("user_profiles")
}

/// Persisted refresh-token records enabling rotation and reuse detection.
///
/// The token handed to the client is a signed JWT; its `jti` maps to `id`
/// here. We also store a SHA-256 hash of the exact token string for
/// defense-in-depth (a leaked DB alone cannot reconstruct a usable token).
/// On refresh the presented token is rotated: the old record is revoked and
/// `replacedById` points to its successor, so replaying a revoked token is
/// detectable as reuse and triggers revocation of the whole lineage.
model RefreshToken {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SHA-256 hash of the issued refresh-token string.
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  /// Successor token id after rotation (reuse-detection lineage).
  replacedById String?
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Account lifecycle domain (Sprint 10)
// ---------------------------------------------------------------------------

/// The purpose of a single-use account token.
enum AccountTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

/// Single-use, expiring tokens for email verification and password reset.
///
/// Only a SHA-256 hash of the opaque token is stored (never the raw token), so
/// a leaked database cannot be used to forge a valid token. A token is valid
/// only while `usedAt` is null and `expiresAt` is in the future — enforcing
/// both one-time usage and expiration. Rows are retained after use as a short
/// audit trail and can be pruned by a later maintenance job.
model AccountToken {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AccountTokenType
  /// SHA-256 hash of the issued opaque token string.
  tokenHash String           @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, type])
  @@map("account_tokens")
}

/// Security-relevant account actions worth auditing.
enum AuditAction {
  EMAIL_VERIFICATION_REQUESTED
  EMAIL_VERIFIED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  PASSWORD_CHANGED
  ACCOUNT_DELETION_REQUESTED
  ACCOUNT_DELETION_CANCELED
  ACCOUNT_DELETED
  BLOOD_TEST_UPLOADED
  BLOOD_TEST_REPLACED
  BLOOD_TEST_DELETED
  SUBSCRIPTION_CHECKOUT_STARTED
  SUBSCRIPTION_ACTIVATED
  SUBSCRIPTION_CANCELED
  SUBSCRIPTION_EXPIRED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  PAYMENT_WEBHOOK_RECEIVED
  CONSENT_GRANTED
  CONSENT_WITHDRAWN
}

/// Append-only audit log for security-related account actions.
///
/// `userId` is a plain (non-foreign-key) column on purpose: audit records must
/// survive permanent account deletion, so no cascade relation is declared.
/// `metadata` carries small, non-sensitive contextual details (never secrets).
model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  action    AuditAction
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Blood test upload domain (Sprint 11)
// ---------------------------------------------------------------------------

/// Lifecycle status of an uploaded blood-test file.
///
/// This sprint only ever sets `UPLOADED`. The remaining values exist so the
/// AI-analysis sprint can advance a record through processing without a schema
/// migration or breaking changes — the upload infrastructure is intentionally
/// forward-compatible with a downstream consumer.
enum BloodTestStatus {
  UPLOADED
  ANALYZING
  ANALYZED
  FAILED
}

/// A single uploaded blood-test document (PDF lab report or image).
///
/// The binary is never stored in the database — it lives in the configured
/// storage backend and is referenced here by `storageProvider` + `storageKey`,
/// so the provider can change without touching this contract. Only metadata and
/// integrity fields are persisted. `checksumSha256` lets a later stage verify
/// the fetched bytes match what was uploaded. `metadata` is a small, extensible
/// JSON bag for optional user-supplied context (e.g. lab name); it never holds
/// extracted medical values.
model BloodTestUpload {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           BloodTestStatus @default(UPLOADED)
  /// Storage backend identifier (e.g. "local", "s3") that owns `storageKey`.
  storageProvider  String
  /// Opaque key/path locating the object within the storage backend.
  storageKey       String
  /// Original client-provided filename (sanitized), for display/download.
  originalFilename String
  mimeType         String
  fileSizeBytes    Int
  /// SHA-256 hex digest of the stored bytes (integrity verification).
  checksumSha256   String
  /// Optional user-provided label for the upload.
  label            String?
  /// Optional date the blood test was taken (not the upload time).
  testDate         DateTime?       @db.Date
  /// Small, non-sensitive extensible context. Never extracted medical values.
  metadata         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  /// One-to-one AI analysis produced by the Sprint 12 analysis engine.
  analysis BloodTestAnalysis?

  @@index([userId])
  @@index([userId, status])
  @@map("blood_test_uploads")
}

// ---------------------------------------------------------------------------
// AI blood-test analysis domain (Sprint 12)
// ---------------------------------------------------------------------------

/// Lifecycle status of an AI blood-test analysis run.
enum BloodTestAnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

/// The structured result of running Diewish's AI Blood Test Analysis Engine
/// over an uploaded blood-test document.
///
/// The engine extracts laboratory values (text → OCR → vision), normalizes and
/// compares them against reference ranges, then asks a provider-agnostic AI
/// adapter for plain-language explanations and *nutrition-focused* implications.
/// This is explicitly NOT a medical-diagnosis record: all AI output is
/// educational/nutritional and carries a disclaimer. The structured JSON fields
/// are intentionally reusable by downstream features (nutrition plan generator,
/// dietitian chat, progress tracking, future health reports).
model BloodTestAnalysis {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// The uploaded blood-test document this analysis was produced from.
  bloodTestId String          @unique
  bloodTest   BloodTestUpload @relation(fields: [bloodTestId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status           BloodTestAnalysisStatus @default(PENDING)
  /// Which extraction path produced the values: "TEXT", "OCR" or "VISION".
  extractionMethod String?

  /// Raw text recovered from the document (for auditing/re-processing).
  rawExtractedText String? @db.Text
  /// NormalizedBloodTestValue[] — the full normalized value set.
  normalizedValues Json
  /// Subset of normalizedValues whose status != NORMAL.
  abnormalValues   Json
  abnormalCount    Int     @default(0)

  /// Per-biomarker plain-language explanations.
  aiExplanations         Json
  /// Nutrition-focused implications per abnormal value.
  nutritionImplications  Json
  /// Ordered list of nutrition recommendations.
  overallRecommendations Json

  /// 2–3 sentence plain-language summary (with disclaimer).
  summary String? @db.Text

  aiProvider       String?
  aiModel          String?
  processingTimeMs Int?

  errorMessage String?

  @@index([userId])
  @@index([bloodTestId])
  @@map("blood_test_analyses")
}

/// Gender scope for a reference range.
enum ReferenceRangeGender {
  MALE
  FEMALE
  ALL
}

/// A database-driven reference range for a single biomarker.
///
/// Ranges are looked up by `biomarkerCode` and filtered by gender/age/country/
/// laboratory so the analysis engine can pick the most specific applicable
/// range. Seeded with ~30 common biomarkers using standard (WHO/ADA) values.
model BloodTestReferenceRange {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  biomarkerCode   String
  biomarkerName   String
  /// Turkish display name for i18n.
  biomarkerNameTr String?
  unit            String

  minValue   Float?
  maxValue   Float?
  /// Optimal sub-range within the normal range (nullable).
  optimalMin Float?
  optimalMax Float?

  gender ReferenceRangeGender @default(ALL)
  ageMin Int?
  ageMax Int?

  /// ISO 3166-1 alpha-2 country code; null = universal.
  country      String?
  /// Lab-specific range owner; null = generic.
  laboratoryId String?

  isActive Boolean @default(true)
  source   String  @default("STANDARD")
  notes    String?

  @@index([biomarkerCode])
  @@index([isActive])
  @@map("blood_test_reference_ranges")
}

// ---------------------------------------------------------------------------
// Personalized nutrition plan domain (Sprint 13)
// ---------------------------------------------------------------------------

/// Plan horizon. Diewish generates 30- and 60-day personalized plans.
enum NutritionPlanDuration {
  THIRTY_DAY
  SIXTY_DAY
}

/// Lifecycle status of a nutrition-plan generation run.
enum NutritionPlanStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

/// A generated personalized nutrition plan produced by Diewish's Nutrition Plan
/// Engine (Sprint 13).
///
/// A plan combines the mandatory onboarding profile (Sprint 9) with the optional
/// latest blood-test analysis (Sprint 12): deterministic calorie/macro/water/
/// meal-timing calculations plus AI-generated meal content and plain-language
/// explanations. Plans are IMMUTABLE and VERSIONED — regenerating creates a new
/// row (version N+1) and only the newest per (user, duration) is `isActive`;
/// previous plans are retained so history is never lost. The JSON columns are
/// intentionally reusable by downstream features (dashboard, dietitian chat,
/// progress tracking, future health reports).
///
/// Safety: nothing here is medical diagnosis, treatment, or prescription; all
/// content is educational/nutritional and carries a disclaimer.
model NutritionPlan {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Optional soft link to the Sprint 12 blood-test analysis used as input.
  /// Kept as a plain column (not a FK relation) so the Sprint 12 model is left
  /// untouched and deleting an analysis never cascades into plan history.
  bloodTestAnalysisId String?

  duration NutritionPlanDuration
  version  Int                   @default(1)
  isActive Boolean               @default(true)
  status   NutritionPlanStatus   @default(COMPLETED)

  // --- Deterministic calculation outputs ---
  bmr           Float
  tdee          Float
  dailyCalories Float
  proteinGrams  Float
  carbsGrams    Float
  fatGrams      Float
  waterMl       Float
  mealsPerDay   Int

  // --- Structured content (reusable JSON) ---
  /// MealTimingRecommendation — recommended meal slots and times.
  mealTiming      Json
  /// NutritionPlanContent — the weekly rotation cycle mapped across all days.
  dailyPlans      Json
  /// PlanExplanations — plain-language rationale per recommendation.
  explanations    Json
  /// Ordered list of overall nutrition recommendations.
  recommendations Json

  /// 2-3 sentence plain-language summary (with disclaimer).
  summary String? @db.Text

  aiProvider       String?
  aiModel          String?
  processingTimeMs Int?
  errorMessage     String?

  @@index([userId])
  @@index([userId, duration, isActive])
  @@map("nutrition_plans")
}

// ---------------------------------------------------------------------------
// AI usage quota & subscription tiers domain (Sprint 14, C5)
// ---------------------------------------------------------------------------

/// Subscription tier used to resolve AI usage quotas. This is intentionally a
/// lightweight enum owned here (not a full payments/subscription system — that
/// is Sprint 15). It lets AI quota checks be "subscription-aware" today while
/// defaulting every account to FREE until payments assign a paid tier.
enum SubscriptionTier {
  FREE
  PREMIUM
  PREMIUM_PLUS
}

/// The AI-consuming feature a usage event belongs to. Adding a value here lets
/// any AI surface adopt the shared quota/cost-protection capability without a
/// breaking change.
enum AiUsageFeature {
  DIETITIAN_CHAT
  BLOOD_TEST_ANALYSIS
  NUTRITION_PLAN
}

/// Append-only record of a single billable AI invocation (Sprint 14, C5).
///
/// One row is written per successful external AI call. Counting rows within a
/// rolling window powers both per-tier quota enforcement (cost-explosion
/// protection) and an auditable usage trail. No prompt content or PHI is stored
/// here — only the feature, provider/model, and a coarse token estimate.
model AiUsageEvent {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature         AiUsageFeature
  provider        String
  model           String
  /// Best-effort estimate of tokens consumed, for cost observability. Optional
  /// because not every provider returns usage; never used for enforcement math.
  estimatedTokens Int?
  createdAt       DateTime       @default(now())

  @@index([userId, feature, createdAt])
  @@map("ai_usage_events")
}

// ---------------------------------------------------------------------------
// AI Dietitian Chat domain (Sprint 14, C2)
// ---------------------------------------------------------------------------

/// Author of a chat message.
enum ChatRole {
  USER
  ASSISTANT
}

/// A single AI Dietitian Chat conversation thread owned by a user.
///
/// Conversations group an ordered list of messages so the orchestrator can
/// supply bounded history back to the model. All access is owner-scoped.
model ChatConversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Short human-readable label derived from the first user message.
  title String?

  messages ChatMessage[]

  @@index([userId])
  @@map("chat_conversations")
}

/// A single message within a conversation.
///
/// User messages store the user's original text (Diewish owns this data);
/// PHI minimization is applied only to the copy sent to the external AI, never
/// to what is persisted here. Assistant messages carry provider/model metadata
/// for observability. All AI replies are nutrition-only and disclaimer-bound.
model ChatMessage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    ChatRole
  content String   @db.Text

  /// Assistant-only: which provider/model produced the reply (null for user).
  provider String?
  model    String?

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

// ---------------------------------------------------------------------------
// Subscription & payments domain (Sprint 15, D1–D3)
// ---------------------------------------------------------------------------

/// Lifecycle status of a subscription record.
///
/// A user may have at most one non-terminal (ACTIVE / PENDING / PAST_DUE)
/// subscription at a time; CANCELED/EXPIRED rows are retained for history and
/// audit. Tier entitlements are resolved from the User's `subscriptionTier`,
/// which this module keeps in sync with the active subscription.
enum SubscriptionStatus {
  /// Checkout initiated; awaiting a successful payment/webhook confirmation.
  PENDING
  /// Paid and currently entitling the user to the tier's features.
  ACTIVE
  /// Payment failed on renewal; grace handling is a future concern (P4).
  PAST_DUE
  /// Canceled by the user; may remain entitling until `currentPeriodEnd`.
  CANCELED
  /// Term elapsed without renewal; no longer entitling.
  EXPIRED
}

/// Payment processor. Modeled as an enum so the payment layer stays modular and
/// additional providers (e.g. Stripe — roadmap F9) can be added without a
/// breaking change to callers.
enum PaymentProvider {
  IYZICO
}

/// Lifecycle status of a single payment attempt.
enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

/// A subscription purchased (or being purchased) by a user.
///
/// The provider-side identifiers (`providerRef`, `providerSubscriptionRef`) let
/// the record be reconciled against iyzico without leaking processor internals
/// into the rest of the app. `cancelAtPeriodEnd` supports "cancel but keep
/// access until the paid term ends" (App Store 3.1.2 / Play cancellation UX).
model Subscription {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier     SubscriptionTier
  status   SubscriptionStatus @default(PENDING)
  provider PaymentProvider    @default(IYZICO)

  /// Provider-side conversation/checkout reference used to correlate webhooks.
  providerRef             String?
  /// Provider-side recurring-subscription reference (if applicable).
  providerSubscriptionRef String?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?

  payments Payment[]

  @@index([userId])
  @@index([status])
  @@index([providerRef])
  @@map("subscriptions")
}

/// A single payment attempt against a subscription.
///
/// `providerPaymentId` and `providerConversationId` are the iyzico correlation
/// keys. `rawStatus` preserves the processor's own status string for support
/// and reconciliation; `status` is the normalized lifecycle value the app acts
/// on. Amounts are stored in minor units (kuruş) to avoid float rounding.
model Payment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  provider PaymentProvider @default(IYZICO)
  status   PaymentStatus   @default(PENDING)

  /// Amount in minor currency units (e.g. kuruş for TRY).
  amountMinor Int
  currency    String @default("TRY")

  providerPaymentId      String?
  providerConversationId String?
  /// Processor's own status string, preserved verbatim for reconciliation.
  rawStatus              String?
  /// Non-sensitive failure reason surfaced to support (never card data).
  failureReason          String?

  @@index([userId])
  @@index([subscriptionId])
  @@index([providerConversationId])
  @@map("payments")
}

/// Append-only log of inbound payment-provider webhook events.
///
/// `providerEventId` is UNIQUE so replays are idempotent — a duplicate delivery
/// is detected and short-circuited rather than double-applying a state change
/// (an unverified/replayed webhook must never grant free premium). The raw
/// payload is retained for audit and reprocessing.
model PaymentWebhookEvent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  provider        PaymentProvider @default(IYZICO)
  /// Provider-unique event identifier used for idempotent processing.
  providerEventId String          @unique
  eventType       String?
  /// Whether the signature verified against the configured secret.
  signatureValid  Boolean         @default(false)
  /// Whether business processing completed successfully.
  processedAt     DateTime?
  payload         Json

  @@index([provider])
  @@map("payment_webhook_events")
}

// ---------------------------------------------------------------------------
// Legal / consent compliance domain (Sprint 15, B1–B4)
// ---------------------------------------------------------------------------

/// A category of legal document / consent. Health data processing (KVKK m.6)
/// requires explicit, versioned, withdrawable consent; the store forms (Play
/// Data Safety, App Store) require accessible Privacy Policy & Terms.
enum LegalDocumentType {
  PRIVACY_POLICY
  TERMS_OF_SERVICE
  MEDICAL_DISCLAIMER
  KVKK_EXPLICIT_CONSENT
}

/// A single user consent decision for a specific document version.
///
/// Consent is VERSIONED (a new document version requires re-consent) and
/// WITHDRAWABLE (`withdrawnAt`): the latest row per (user, type) is the current
/// state — `granted && withdrawnAt == null` means active consent. Rows are
/// append-only for an auditable trail (KVKK accountability). Consent records
/// survive normal reads but are removed with the account on permanent deletion
/// (cascade) since they are personal data tied to the subject.
model ConsentRecord {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            LegalDocumentType
  /// Version of the document the user acted on (e.g. "2026-07-01").
  documentVersion String
  granted         Boolean
  grantedAt       DateTime?
  withdrawnAt     DateTime?

  ipAddress String?
  userAgent String?

  @@index([userId, type, createdAt])
  @@map("consent_records")
}
