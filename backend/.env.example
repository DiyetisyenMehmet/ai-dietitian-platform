# ─────────────────────────────────────────────────────────────
# Diewish — Backend environment (example)
# Copy to `.env` and adjust values for your environment.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000

# API
API_PREFIX=/api
CORS_ORIGIN=http://localhost:3000

# Logging: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Rate limiting (global)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Rate limiting (auth endpoints — stricter)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://dietitian:dietitian_dev_pw@127.0.0.1:5432/ai_dietitian?schema=public"

# Authentication (Sprint 8)
# Generate strong secrets, e.g.: openssl rand -hex 32
JWT_ACCESS_SECRET="change-me-min-32-chars-access-secret-000000"
JWT_REFRESH_SECRET="change-me-min-32-chars-refresh-secret-00000"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
REFRESH_TOKEN_TTL_DAYS=7
JWT_ISSUER=diewish
BCRYPT_ROUNDS=12

# Account lifecycle (Sprint 10)
APP_WEB_URL=http://localhost:3000
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=60
ACCOUNT_DELETION_GRACE_DAYS=30

# File storage / blood-test uploads (Sprint 11)
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=./storage/uploads
BLOOD_TEST_MAX_FILE_SIZE_MB=15


# AI Blood Test Analysis Engine (Sprint 12)
# Provider-agnostic, OpenAI-compatible chat/completions API. Works with OpenAI,
# Mistral, Together, Groq, and any endpoint implementing the OpenAI schema.
AI_API_KEY=your-api-key-here
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.2
# Minimum meaningful chars from text extraction before OCR fallback kicks in.
BLOOD_TEST_TEXT_MIN_CHARS=100



# Payments & Subscriptions (Sprint 15)
# Payment provider. Only "iyzico" is implemented.
PAYMENT_PROVIDER=iyzico
# iyzico environment: "sandbox" (default) or "production".
IYZICO_ENV=sandbox
# Base URL. Sandbox by default; use https://api.iyzipay.com for production.
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# iyzico API credentials (from the iyzico merchant dashboard). Leave blank in
# local/dev to keep the payment provider "unconfigured" (checkout returns 503).
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
# Optional dedicated webhook secret. Falls back to IYZICO_SECRET_KEY if unset.
IYZICO_WEBHOOK_SECRET=
# Where iyzico redirects the buyer back to after the hosted checkout form.
IYZICO_CALLBACK_URL=http://localhost:3000/billing/callback
# ISO-4217 currency code for billing. iyzico Turkish accounts use TRY.
BILLING_CURRENCY=TRY

# Legal & Consent document versions (Sprint 15)
# Bump a version (e.g. to a new ISO date) when a document's text changes; users
# will be required to re-accept the corresponding mandatory consent.
LEGAL_PRIVACY_POLICY_VERSION=2026-07-01
LEGAL_TERMS_OF_SERVICE_VERSION=2026-07-01
LEGAL_MEDICAL_DISCLAIMER_VERSION=2026-07-01
LEGAL_KVKK_CONSENT_VERSION=2026-07-01
