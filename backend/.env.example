# ─────────────────────────────────────────────────────────────
# AI Dietitian Platform — Backend environment (example)
# Copy to `.env` and adjust values for your environment.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000

# API
API_PREFIX=/api
CORS_ORIGIN=http://localhost:3000

# Logging: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://dietitian:dietitian_dev_pw@127.0.0.1:5432/ai_dietitian?schema=public"
