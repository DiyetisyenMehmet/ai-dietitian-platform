# ─────────────────────────────────────────────────────────────
# Diewish — Backend PRODUCTION environment (example)
# Copy to `.env` on the server and replace every placeholder with a real,
# secret value. NEVER commit the real .env. Generate secrets with:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=production
PORT=4000

# API — set CORS_ORIGIN to your real frontend origin(s), comma-separated.
API_PREFIX=/api
CORS_ORIGIN=https://diewish.com

# Logging: use "info" or "warn" in production.
LOG_LEVEL=info

# Rate limiting (global)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Rate limiting (auth endpoints — stricter)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# PostgreSQL (Prisma) — use a managed/hardened database with SSL in production.
DATABASE_URL="postgresql://USER:PASSWORD@db-host:5432/diewish?schema=public&sslmode=require"

# Authentication — MUST be strong, unique, ≥32 chars. Rotate on suspicion.
JWT_ACCESS_SECRET="REPLACE_WITH_openssl_rand_hex_32"
JWT_REFRESH_SECRET="REPLACE_WITH_openssl_rand_hex_32"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
REFRESH_TOKEN_TTL_DAYS=7
JWT_ISSUER=diewish
BCRYPT_ROUNDS=12

# Account lifecycle — public URL of the production web frontend.
APP_WEB_URL=https://diewish.com
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=60
ACCOUNT_DELETION_GRACE_DAYS=30

# File storage / blood-test uploads
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=./storage/uploads
BLOOD_TEST_MAX_FILE_SIZE_MB=15

# AI Blood Test Analysis Engine (OpenAI-compatible)
AI_API_KEY=REPLACE_WITH_PRODUCTION_AI_KEY
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.2
BLOOD_TEST_TEXT_MIN_CHARS=100

# Payments & Subscriptions — iyzico PRODUCTION credentials.
PAYMENT_PROVIDER=iyzico
IYZICO_ENV=production
IYZICO_BASE_URL=https://api.iyzipay.com
IYZICO_API_KEY=REPLACE_WITH_LIVE_IYZICO_API_KEY
IYZICO_SECRET_KEY=REPLACE_WITH_LIVE_IYZICO_SECRET_KEY
IYZICO_WEBHOOK_SECRET=REPLACE_WITH_LIVE_IYZICO_WEBHOOK_SECRET
IYZICO_CALLBACK_URL=https://diewish.com/billing/callback
BILLING_CURRENCY=TRY

# Legal & Consent document versions
LEGAL_PRIVACY_POLICY_VERSION=2026-07-01
LEGAL_TERMS_OF_SERVICE_VERSION=2026-07-01
LEGAL_MEDICAL_DISCLAIMER_VERSION=2026-07-01
LEGAL_KVKK_CONSENT_VERSION=2026-07-01
